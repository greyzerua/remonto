{
  "expo": {
    "name": "Remonto",
    "slug": "Remonto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Splash-logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/transparent-logo.png",
      "resizeMode": "cover",
      "backgroundColor": "#E6ECF4"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/transparent-logo.png",
        "backgroundColor": "#E6ECF4"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
